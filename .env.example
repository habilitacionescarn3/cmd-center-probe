# General
APP_PORT=5004
TZ="America/Sao_Paulo"
LOG_LEVEL="debug"

# Database (Docker compose already maps localhost:${POSTGRES_PORT})
POSTGRES_PORT=5001
DATABASE_URL="postgresql://postgres:postgres@localhost:5001/status_page?schema=public"

# NextAuth (replace with secure values in production)
NEXTAUTH_SECRET="replace-me-with-a-strong-secret"
NEXTAUTH_URL="http://localhost:5004"
