{
  "name": "command-center",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prestart": "AUDIT_OMIT_DEV=1 npm run security:check",
    "build": "rm -rf .next && COMMAND_CENTER_SKIP_RUNTIME_DB=1 next build",
    "start": "next start",
    "security:zero-vuln": "AUDIT_FIX=1 bash scripts/ensure-zero-vulnerabilities.sh",
    "security:check": "AUDIT_FIX=0 bash scripts/ensure-zero-vulnerabilities.sh",
    "lint": "next lint",
    "format": "biome format --write .",
    "typecheck": "rm -rf .next && next typegen && tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.62.8",
    "@total-typescript/ts-reset": "^0.6.1",
    "@vercel/analytics": "^1.3.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.0.2",
    "framer-motion": "^11.16.3",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.469.0",
    "next": "^15.5.14",
    "next-auth": "^4.24.7",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "react": "19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "19.2.0",
    "recharts": "^3.4.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-pattern": "^5.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.5.14",
    "msw": "^2.6.0",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.16.2",
    "typescript": "^5.6.2",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "rollup": "^4.60.0",
    "minimatch@^3.0.0": {
      "brace-expansion": "^1.1.13"
    },
    "minimatch@^5.0.0": {
      "brace-expansion": "^2.0.3"
    },
    "minimatch@^9.0.0": {
      "brace-expansion": "^5.0.5"
    },
    "anymatch@^3.0.0": {
      "picomatch": "^2.3.2"
    },
    "micromatch@^4.0.0": {
      "picomatch": "^2.3.2"
    },
    "readdirp@^3.0.0": {
      "picomatch": "^2.3.2"
    },
    "tinyglobby@^0.2.0": {
      "picomatch": "^4.0.4"
    },
    "vite@^7.0.0": {
      "picomatch": "^4.0.4"
    },
    "vitest@^4.0.18": {
      "picomatch": "^4.0.4"
    }
  }
}
